# Example environment variables (copy to .env and fill in your actual keys)
# --- LLM Judge API Key ---
# Choose ONE provider you configured in config/models.yaml and add your key
# Make sure the variable name here EXACTLY matches the 'api_key_env' value in config/models.yaml

# Example for OpenAI:
OPENAI_API_KEY="sk-YOUR_ACTUAL_OPENAI_API_KEY_HERE"

# Example for Anthropic (if you configure it later):
# ANTHROPIC_API_KEY="sk-ant-..."

# Example for Google AI Studio (Gemini) (if you configure it later):
# GOOGLE_API_KEY="AIza..."


# --- Other Optional Keys ---
# HUGGINGFACE_TOKEN="hf_..." # Might be needed if using private models from Hugging Face Hub
